{
  "name": "indrajithc-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run dev.ts",
    "build": "bun run build.ts",
    "preview": "bun run --cwd out http-server . -p 4000 2>/dev/null || bun run serve",
    "css:watch": "bunx tailwindcss -i ./src/styles/global.css -o ./public/styles.css --watch",
    "css:build": "bunx tailwindcss -i ./src/styles/global.css -o ./public/styles.css --minify"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^3",
    "typescript": "^5.6.3"
  }
}
